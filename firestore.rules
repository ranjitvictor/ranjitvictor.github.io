rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /inquiries/{id} {
      // Anyone may submit the contact form, but only with a valid shape
      // (blocks junk writes / spam of arbitrary data).
      allow create: if
        request.resource.data.keys().hasOnly(
          ['name','email','company','message','teamSize','situation','timeline','createdAt','read','source'])
        && request.resource.data.name is string    && request.resource.data.name.size()    >= 1
        && request.resource.data.name.size()    <= 120
        && request.resource.data.email is string   && request.resource.data.email.size()   >= 3
        && request.resource.data.email.size()   <= 200
        && request.resource.data.message is string && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 4000
        && request.resource.data.read == false;

      // Only the owner's verified Google account can read or update.
      allow read, update: if request.auth != null
        && request.auth.token.email == 'ranjitvictor@gmail.com'
        && request.auth.token.email_verified == true;

      allow delete: if false;
    }

    // Everything else is locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
